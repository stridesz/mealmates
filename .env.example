# Google Sheets integration (optional — waitlist still works without these)
# Create a Google Service Account, share your sheet with it, then paste creds below.

GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Paste the private key from the JSON credentials file.
# Keep the -----BEGIN/END----- markers. Replace literal newlines with \n.
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
